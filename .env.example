# Supabase Connection Info (Found under Settings -> API in your Supabase project)
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Google AI Studio Gemini API Key (Optional, fallback to browser session token if not set)
VITE_GEMINI_API_KEY=your-gemini-api-key
VITE_GCP_PROJECT_ID=your-gcp-project-id

# GitHub Access Token (Optional, used for loading source code directly from GitHub)
VITE_GITHUB_TOKEN=your-github-token
